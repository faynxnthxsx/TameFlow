# Supabase project settings — Project Settings > API in the Supabase dashboard




NUXT_PUBLIC_SUPABASE_URL=
NUXT_PUBLIC_SUPABASE_KEY=

# Service-role key — Project Settings > API. Server-only, never expose to the client.
# Used by server/api/* routes that need to bypass RLS (e.g. invite acceptance).
SUPABASE_SERVICE_ROLE_KEY=
